<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class="com.capgemini.java_development.java_advanced.framework.spring.core.entity.Project" id="project">
    	<constructor-arg index="0" value="1"/>
    	<constructor-arg index="1" value="ChatBot"/>
    	<constructor-arg index="2" value="AI based"/>
    </bean>
    
    <bean class="com.capgemini.java_development.java_advanced.framework.spring.core.entity.Student" id="student">
    	<property name="id" value="1"/>
    	<property name="name" value="Raja"/>
    	<property name="mailId" value="raja@gmail.com"/>
    	<property name="contactNumber" value="8558562253"/>
    	<property name="project" ref="project"/>
    </bean>

</beans>